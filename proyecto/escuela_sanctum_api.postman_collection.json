              "raw": "{\n  \"name\": \"Materia API Editada\",\n  \"code\": \"API-EDIT-{{ $randomInt }}\"\n}"
            },
            "url": "{{base_url}}/api/subjects/{{subject_id}}"
          }
        },
        {
          "name": "Delete Subject",
          "request": {
            "method": "DELETE",
