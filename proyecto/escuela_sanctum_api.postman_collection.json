{
  "info": {
    "_postman_id": "9b2675c0-8fe0-4f2a-9f1f-f706a6fe8f40",
    "name": "Escuela API Sanctum",
    "description": "Coleccion para probar autenticacion Sanctum y CRUD completo de classrooms, students, subjects y enrollments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost/escuela/public" },
    { "key": "token", "value": "" },
    { "key": "student_id", "value": "1" },
    { "key": "classroom_id", "value": "1" },
    { "key": "subject_id", "value": "1" },
    { "key": "enrollment_id", "value": "1" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman.user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201/422', function () {",
                  "  pm.expect([201, 422]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  var data = pm.response.json();",
                  "  if (data.access_token) {",
                  "    pm.collectionVariables.set('token', data.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@escuela.test\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/logout"
          }
        }
      ]
    },
    {
      "name": "02 Classrooms",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{token}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "List Classrooms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/classrooms"
          }
        },
        {
          "name": "Create Classroom",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aula API {{ $randomInt }}\",\n  \"capacity\": 32\n}"
            },
            "url": "{{base_url}}/api/classrooms"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if ([200,201].includes(pm.response.code)) {",
                  "  var data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('classroom_id', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Classroom",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aula API Editada\",\n  \"capacity\": 35\n}"
            },
            "url": "{{base_url}}/api/classrooms/{{classroom_id}}"
          }
        },
        {
          "name": "Delete Classroom",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/classrooms/{{classroom_id}}"
          }
        }
      ]
    },
