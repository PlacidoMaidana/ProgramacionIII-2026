              "raw": "{\n  \"classroom_id\": {{classroom_id}},\n  \"name\": \"Alumno API Editado\",\n  \"email\": \"alumno.api.edit.{{ $randomInt }}@example.com\"\n}"
            },
            "url": "{{base_url}}/api/students/{{student_id}}"
          }
        },
        {
          "name": "Delete Student",
          "request": {
